<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <%- include('./partials/dashboard/navbar') %>
    <div class="container">
        <h4><%= data.title %></h4>
        <h5>Date: <%= data.date %></h5>
        <a target="_blank" class="btn btn-primary btn-sm" href="<%= data.audio_link %>">Audio File</a>
        <a target="_blank" class="btn btn-primary btn-sm" href="<%= data.text_link %>">Transcript</a>
        <a target="_blank" class="btn btn-warning btn-sm" href="/add">Go Back to Dashboard</a>

        <hr>

        <p class="small" align="justify">
            <%= data.text %>
        </p>

        <h4>Named Entity Recognition</h4>

        <% if(result && result.length>0)  {%>

           

            <% result.forEach(function(result){ %>

                <% if(result.entity=='PER') { %>

                    <span class="badge text-bg-primary"><%= result.word %> (SCORE: <%= Math.round(result.score*100) %>%)</span>

                
                <% } else if (result.entity == 'ORG') { %>

                        <span class="badge text-bg-warning"><%= result.word %> (SCORE: <%= Math.round(result.score*100) %>%)</span>


                    <% } else if (result.entity == 'MISC') {%>
                        <span class="badge text-bg-secondary"><%= result.word %> (SCORE: <%= Math.round(result.score*100) %>%)</span>

             
            <% } %>

         
            
            <% }) %>
<hr>
               <table class="table">
                <tr>
                    <th colspan="3">LEGEND</th>
                </tr>
                <tr>
                    <td><span class="badge text-bg-secondary">MISC</span></td>
                    <td><span class="badge text-bg-primary">PER</span></td>
                    <td><span class="badge text-bg-warning">ORG</span></td>
                </tr>
            </table>

        <% } else { %>
            <p class="small">No Data Found!</p>

            <% } %>

    </div>
    <%- include('partials/footer') %>
</body>
</html>